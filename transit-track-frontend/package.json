  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern .eslintrc.js",
    "type-check": "node scripts/type-check.js",
    "smoke": "node -e \"const fs=require('fs'); const required=['App.js','screens/HomeScreen.js','screens/StopDetailScreen.js','services/api.js']; required.forEach((f)=>{if(!fs.existsSync(f)){throw new Error('Missing '+f);}}); console.log('Frontend smoke check passed');\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "axios": "^1.15.2",
    "expo": "^55.0.18",
    "expo-font": "~14.0.11",
    "expo-notifications": "^55.0.21",
    "expo-splash-screen": "^55.0.19",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5"
  }
